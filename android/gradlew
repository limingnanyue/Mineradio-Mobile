#!/bin/sh
# Gradle wrapper 启动脚本（标准模板）。Android Studio 会自动生成完整 wrapper jar。
# 命令行构建： ./gradlew assembleDebug  （首次需用 Android Studio 同步一次以生成 wrapper jar）
set -e
APP_HOME=$(cd "$(dirname "$0")" && pwd)
exec java -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
