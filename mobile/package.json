{
  "name": "mineradio-mobile",
  "version": "1.1.1",
  "description": "Mineradio 移动端壳（iOS / Android），UI 与桌面版完全一致，仅做移动端适配。",
  "private": true,
  "scripts": {
    "sync": "cap sync",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "copy": "cap copy",
    "build:web": "echo 'No build step — public/ is served as-is.'"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/browser": "^6.0.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@capacitor-community/cordova": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
